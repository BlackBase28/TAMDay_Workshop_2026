---
# Example only. The real vars/host_passwords.yml is intentionally not included
# in this package because it is environment-specific and must not be overwritten.
#
# The dictionary key must match inventory_hostname, not ansible_host.
# Example inventory:
#   inventory hostname: testclone.blackbase.com
#   ansible_host: 192.168.1.204
#   ansible_user: lab-user
#
# Example password mapping before encryption:
cve_radar_host_passwords:
  "testclone.blackbase.com": "replace-with-host-password"

# Encrypt the real file with the Vault Credential already attached to the AAP
# Job Template, for example:
#   ansible-vault encrypt vars/host_passwords.yml
